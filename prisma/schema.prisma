// HexaKode - Prisma Schema
// Database: Supabase PostgreSQL
// ORM: Prisma 7
// Focus: Authentication & Operational Data

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PasswordResetStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  EXPIRED
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  ARCHIVED
}

enum DemoStatus {
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

/// Application user accounts.
/// Supports future Auth.js integration.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  supabaseId   String?    @unique
  name         String
  email        String     @unique
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs             AuditLog[]
  passwordResetRequests PasswordResetRequest[] @relation("PasswordResetUser")
  approvedResets        PasswordResetRequest[] @relation("PasswordResetApprover")

  @@index([email])
  @@index([status])
  @@map("users")
}

/// Admin-approved password reset workflow.
/// User requests → Main Admin approves/rejects.
model PasswordResetRequest {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  status      PasswordResetStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  approvedAt  DateTime?
  approvedBy  String?             @db.Uuid

  user     User  @relation("PasswordResetUser", fields: [userId], references: [id])
  approver User? @relation("PasswordResetApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("password_reset_requests")
}

/// Immutable audit trail for all admin/system actions.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Contact form / project enquiry submissions.
model Enquiry {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String?
  company      String?
  service      String?
  budget       String?
  couponCode   String?
  referralCode String?
  referredBy   String?
  message      String
  status       EnquiryStatus @default(NEW)
  createdAt    DateTime      @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("enquiries")
}

model Coupon {
  id               String    @id @default(uuid()) @db.Uuid
  code             String    @unique
  referrerName     String?
  rewardType       String?
  notes            String?
  startDate        DateTime  @default(now())
  activeDays       Int?      @default(30)
  maxLimit         Int       @default(5)
  currentEnquiries Int       @default(0)
  expiryType       String    @default("custom")
  expiryDate       DateTime?
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("coupons")
}

/// Key-value store for dynamic system configuration.
model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

/// Demo scheduling requests.
model DemoRequest {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  company     String
  phone       String
  email       String
  status      DemoStatus  @default(NEW)
  meetingLink String?
  meetingTime DateTime?
  notes       String?
  source      String?
  inquiryType String?
  createdAt   DateTime    @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("demo_requests")
}

// ─────────────────────────────────────────────
// Client Portal
// ─────────────────────────────────────────────

/// Client accounts managed in the admin portal.
model Client {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  email             String?
  phone             String?
  company           String?
  websiteUrl        String?
  status            String              @default("Active")
  creditBalance     Float               @default(0.0)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  projects          Project[]
  invoices          Invoice[]
  creditTransactions CreditTransaction[]

  @@index([name])
  @@map("clients")
}

/// Projects associated with clients.
model Project {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  clientId        String           @db.Uuid
  websiteUrl      String?
  adminUrl        String?
  status          String           @default("Active")
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]
  invoices        Invoice[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

/// Maintenance log entries for projects.
model MaintenanceLog {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  title       String
  description String?
  logDate     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([logDate])
  @@map("maintenance_logs")
}

model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  clientId      String   @db.Uuid
  projectId     String?  @db.Uuid
  invoiceNumber String   @unique
  amount        Float
  creditApplied  Float    @default(0)
  finalAmountDue Float    @default(0)
  status        String   @default("Pending") // "Paid", "Pending", "Overdue"
  dueDate       DateTime
  issuedDate    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@map("invoices")
}

model CreditTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("credit_transactions")
}