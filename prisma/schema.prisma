// HexaKode - Prisma Schema
// Database: Supabase PostgreSQL
// ORM: Prisma 7
// Focus: Authentication & Operational Data

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PasswordResetStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  EXPIRED
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  ARCHIVED
}

enum DemoStatus {
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

/// Application user accounts.
/// Supports future Auth.js integration.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  supabaseId   String?    @unique
  name         String
  email        String     @unique
  passwordHash String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  auditLogs             AuditLog[]
  passwordResetRequests PasswordResetRequest[] @relation("PasswordResetUser")
  approvedResets        PasswordResetRequest[] @relation("PasswordResetApprover")

  @@index([email])
  @@index([status])
  @@map("users")
}

/// Admin-approved password reset workflow.
/// User requests → Main Admin approves/rejects.
model PasswordResetRequest {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  status      PasswordResetStatus @default(PENDING)
  requestedAt DateTime            @default(now())
  approvedAt  DateTime?
  approvedBy  String?             @db.Uuid

  user     User  @relation("PasswordResetUser", fields: [userId], references: [id])
  approver User? @relation("PasswordResetApprover", fields: [approvedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("password_reset_requests")
}

/// Immutable audit trail for all admin/system actions.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Contact form / project enquiry submissions.
model Enquiry {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  email        String
  phone        String?
  company      String?
  service      String?
  budget       String?
  couponCode   String?
  referralCode String?
  referredBy   String?
  message      String
  status       EnquiryStatus @default(NEW)
  createdAt    DateTime      @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("enquiries")
}

model Coupon {
  id               String    @id @default(uuid()) @db.Uuid
  code             String    @unique
  referrerName     String?
  rewardType       String?
  clientId         String?   @db.Uuid
  clientName       String?
  notes            String?
  startDate        DateTime  @default(now())
  activeDays       Int?      @default(30)
  maxLimit         Int       @default(5)
  currentEnquiries Int       @default(0)
  expiryType       String    @default("custom")
  expiryDate       DateTime?
  enabled          Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  client           Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("coupons")
}

/// Key-value store for dynamic system configuration.
model SystemSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

/// Demo scheduling requests.
model DemoRequest {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  company     String
  phone       String
  email       String
  status      DemoStatus  @default(NEW)
  meetingLink String?
  meetingTime DateTime?
  notes       String?
  source      String?
  inquiryType String?
  createdAt   DateTime    @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@map("demo_requests")
}

// ─────────────────────────────────────────────
// Client Portal
// ─────────────────────────────────────────────

/// Client accounts managed in the admin portal.
model Client {
  id                String              @id @default(uuid()) @db.Uuid
  name              String
  email             String?
  phone             String?
  company           String?
  websiteUrl        String?
  status            String              @default("Active")
  creditBalance     Float               @default(0.0)
  notes             String?
  userId            String?             @db.Uuid
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  projects          Project[]
  invoices          Invoice[]
  creditTransactions CreditTransaction[]
  coupons           Coupon[]

  @@index([name])
  @@map("clients")
}

/// Projects associated with clients.
model Project {
  id              String           @id @default(uuid()) @db.Uuid
  name            String
  clientId        String           @db.Uuid
  projectType     String           @default("web") // "web" | "mobile"
  websiteUrl      String?
  adminPanelUrl   String?
  androidPackage  String?
  iosBundleId     String?
  playStoreUrl    String?
  appStoreUrl     String?
  repositoryUrl   String?
  status          String           @default("Active")
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  maintenanceLogs MaintenanceLog[]
  invoices        Invoice[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

/// Maintenance log entries for projects.
model MaintenanceLog {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @db.Uuid
  title       String
  description String?
  logDate     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoices    Invoice[] @relation("InvoiceMaintenanceLogs")

  @@index([projectId])
  @@index([logDate])
  @@map("maintenance_logs")
}

model Invoice {
  id                     String   @id @default(uuid()) @db.Uuid
  clientId               String   @db.Uuid
  projectId              String?  @db.Uuid
  invoiceNumber          String   @unique
  amount                 Float
  discountType           String   @default("amount")  // "amount" | "percentage"
  discountValue          Float    @default(0)          // Raw entered value (₹ or %)
  discountAmount         Float    @default(0)          // Calculated monetary discount
  creditApplied          Float    @default(0)
  finalAmountDue         Float    @default(0)
  startingCreditBalance  Float?   // Client credit balance BEFORE deduction (for PDF audit)
  creditTransactionId    String?  @db.Uuid // ID of the CreditTransaction created when credits were applied
  status                 String   @default("Pending") // "Paid", "Pending", "Overdue"
  dueDate                DateTime
  issuedDate             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  client                 Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project                Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  maintenanceLogs        MaintenanceLog[] @relation("InvoiceMaintenanceLogs")

  @@index([clientId])
  @@index([projectId])
  @@map("invoices")
}

model CreditTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  clientId    String   @db.Uuid
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("credit_transactions")
}

model PortfolioProject {
  id               String         @id @default(uuid()) @db.Uuid
  title            String
  slug             String         @unique
  category         String
  clientName       String         @default("")
  projectUrl       String         @default("")
  shortDescription String
  fullDescription  String         @default("")
  coverImage       String         @default("")
  featured         Boolean        @default(false)
  showOnHomepage   Boolean        @default(false)
  allowPreview     Boolean        @default(true)
  status           String         @default("Draft") // "Draft" | "Published"
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // SEO fields
  metaTitle        String         @default("")
  metaDescription  String         @default("")
  ogImage          String         @default("")

  gallery          GalleryImage[]
  technologies     Technology[]
  features         Feature[]

  @@map("portfolio_projects")
}

model GalleryImage {
  id           String           @id @default(uuid()) @db.Uuid
  portfolioId  String           @db.Uuid
  imageUrl     String
  displayOrder Int              @default(0)
  alt          String           @default("")
  project      PortfolioProject @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_gallery_images")
}

model Technology {
  id          String           @id @default(uuid()) @db.Uuid
  portfolioId String           @db.Uuid
  name        String
  project     PortfolioProject @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_technologies")
}

model Feature {
  id           String           @id @default(uuid()) @db.Uuid
  portfolioId  String           @db.Uuid
  title        String
  description  String
  displayOrder Int              @default(0)
  project      PortfolioProject @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("portfolio_features")
}